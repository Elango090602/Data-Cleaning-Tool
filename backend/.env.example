UPLOAD_DIR=./tmp/uploads
OUTPUT_DIR=./tmp/outputs
MAX_FILE_SIZE_MB=50
TEMP_FILE_EXPIRY_MINUTES=60
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Database Setup (Supports SQLite and PostgreSQL)
# Local SQLite default: sqlite:///./tmp/database.db
# PostgreSQL (e.g. Supabase): postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=sqlite:///./tmp/database.db

# Security & Sessions
# Set JWT_SECRET to your Supabase JWT Secret (found in Supabase Dashboard > Settings > API)
JWT_SECRET=super-secret-key-change-this-in-production

# Secure Google OAuth Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Resend Email API for OTP dispatch
RESEND_API_KEY=YOUR_RESEND_API_KEY
# Optional custom Resend sender (Defaults to onboarding@resend.dev in dev / otp@leadsanity.com in prod)
RESEND_SENDER=

# Brevo (Sendinblue) Transactional Email API for OTP dispatch
BREVO_API_KEY=YOUR_BREVO_API_KEY
BREVO_SENDER=LeadSanity <otp@leadsanity.com>

# App Host URL
APP_URL=http://localhost:5173


